{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/process-schedules",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "app/api/jobs/send-report/route.ts": {
      "maxDuration": 300,
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "google-ads-reports"
        }
      ]
    }
  }
}